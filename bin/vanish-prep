#!/usr/bin/env python3

import os
import csv
import argparse

def main():
    parser = argparse.ArgumentParser(
        description="Auto-generate a read_pairs.csv for the Vanish Nextflow pipeline."
    )
    parser.add_argument("-d", "--fastq_dir", required=True, help="Path to the directory containing raw FASTQ files")
    parser.add_argument("--r1", default="_R1", help="Suffix identifying forward reads (default: _R1)")
    parser.add_argument("--r2", default="_R2", help="Suffix identifying reverse reads (default: _R2)")
    parser.add_argument("-o", "--out", default="read_pairs.csv", help="Output CSV name (default: read_pairs.csv)")
    
    args = parser.parse_args()

    if not os.path.isdir(args.fastq_dir):
        print(f"Error: Directory '{args.fastq_dir}' does not exist.")
        return

    valid_extensions = ('.fastq.gz', '.fq.gz', '.fastq', '.fq')
    all_files = [f for f in os.listdir(args.fastq_dir) if f.endswith(valid_extensions) and not f.startswith('.')]
    
    if not all_files:
        print(f"No valid FASTQ files found in {args.fastq_dir}")
        return

    samples = []
    processed_files = set()

    r1_files = sorted([f for f in all_files if args.r1 in f])
    
    for r1 in r1_files:
        r2 = r1.replace(args.r1, args.r2)
        if r2 in all_files:
            samples.append([r1, r2])
            processed_files.add(r1)
            processed_files.add(r2)
        else:
            samples.append([r1, ""])
            processed_files.add(r1)

    remaining_files = sorted([f for f in all_files if f not in processed_files])
    for rem in remaining_files:
        if args.r2 not in rem:
            samples.append([rem, ""])
            processed_files.add(rem)

    # Write to CSV with fully commented headers
    with open(args.out, 'w', newline='') as f:
        f.write(f"# Auto-generated by vanish-prep\n")
        f.write(f"# Scanned directory: {args.fastq_dir}\n")
        f.write(f"# R1 suffix: {args.r1} | R2 suffix: {args.r2}\n")
        f.write(f"# fastq_1,fastq_2\n")

        writer = csv.writer(f)
        writer.writerows(samples)

    print(f"Success! Generated '{args.out}' with {len(samples)} samples.")

if __name__ == "__main__":
    main()